{
  "name": "bus-timings",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "start": "expo start --android",
    "prebuild:android": "EXPO_NO_TELEMETRY=1 npx expo prebuild --platform android --no-install --clean",
    "build:android:debug": "EXPO_NO_TELEMETRY=1 npm run prebuild:android && ./compile-android.sh debug",
    "build:android:release": "EXPO_NO_TELEMETRY=1 npm run prebuild:android && ./compile-android.sh release",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/ui": "^56.0.15",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.8",
    "expo-location": "~56.0.15",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "lucide-react-native": "^1.16.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "15.15.4",
    "react-native-webview": "^13.16.1",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~56.0.14",
    "react-dom": "19.2.3",
    "typescript": "~6.0.3"
  }
}
